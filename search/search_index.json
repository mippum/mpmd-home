{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":[" "]},"docs":[{"location":"","title":"\ud648","text":"<p> \ucf58\ud150\uce20 \ubc14\ub85c\uac00\uae30 </p> \ub9de\ucda4\ubc95 \ud034\uc988 22\uc120 \ud034\uc988 <ol> <li>\uce58\ud0a8\uc774 \ub098\uc628\uac8c \uc5b8\uc81c\uc778\ub370 \uae08\uc0c8 \ub2e4 \uba39\uc5c8\ub0d0?</li> <li>\ud30c\uc804\uc744 \ud06c\uac8c \ubd80\uce58\ub824\uace0 \ud558\ub294\ub370 \ub113\uc9c1\ud55c \ud504\ub77c\uc774\ud32c\uc774 \uc788\uc744\uae4c?</li> <li>\ubc30\uac00 \uba87\uc77c\uc9f8 \uc544\ud508\uc9c0 \ubaa8\ub974\uaca0\uc5b4\uc694.</li> <li>\uc624\ub79c\ub9cc\uc5d0 \ub4f1\uc0b0\uc744 \ud574\ubcfc\uae4c?...</li> </ol> \uc5f0\uadf9 \ud584\ub9bf \uc720\uba85 \ub300\uc0ac \ub4e3\uae30 \ud2b8\ub808\uc774\ub108 <p>       \uc8fd\ub290\ub0d0 \uc0ac\ub290\ub0d0 \uadf8\uac83\uc774 \ubb38\uc81c\ub85c\ub2e4. \uc774 \ub354\ub7ec\uc6b4 \uc6b4\uba85\uc758 \ud654\uc0b4\uacfc \ub3cc\ud314\ub9e4\ub97c \uacac\ub38c\ub0b4\ub294 \uac83\uc774 \ub354 \uace0\uadc0\ud55c\uac00. \uc544\ub2c8\uba74 \uace0\ud1b5\uc758 \ubc14\ub2e4\ub97c \ud798\uc73c\ub85c \ub9c9\uc544\u2026     </p> \ub9c1\ucee8 \uc720\uba85 \uc5f0\uc124(\uc601\uc5b4) \ub4e3\uae30 \ud2b8\ub808\uc774\ub108 <p>       \u2026shall have a new birth of freedom\u2014and that government of the people, by the people, for the people, shall not perish from the earth.     </p> \uc218\ub3c4 \ud034\uc988 26\uc120 \ud034\uc988 <ol> <li>\uc601\uad6d(gb)\uc758 \uc218\ub3c4\ub294?</li> <li>\ud504\ub791\uc2a4(fr)\uc758 \uc218\ub3c4\ub294?</li> <li>\uc774\ud0c8\ub9ac\uc544(it)\uc758 \uc218\ub3c4\ub294?</li> <li>\uce90\ub098\ub2e4(ca)\uc758 \uc218\ub3c4\ub294?</li> </ol>"},{"location":"#_1","title":"\ubc14\ub85c\uac00\uae30 \uc694\uc57d","text":"<ul> <li> <p>\uc11c\ube44\uc2a4</p> <ul> <li> <p>\ub4e3\uae30 \ud2b8\ub808\uc774\ub108 \ud2b9\uc815 \ubb38\uad6c\ub97c \uc678\uc6b0\uae30 \uc704\ud574 \ud639\uc740 \uba85\uc0c1\uc744 \uc704\ud574, \ubc18\ubcf5 \ub4e3\uae30\ub97c \ud560 \uc218 \uc788\uc5b4\uc694.</p> </li> <li> <p>\ubbf8\uc068 \ud034\uc988 \ud55c \ubb38\uc81c\uc529 \ub2f5\uc744 \ud655\uc778\ud558\uba70 \ud034\uc988\ub97c \ud480\uc5b4 \ubcfc \uc218 \uc788\ub294 \uc11c\ube44\uc2a4 \uc785\ub2c8\ub2e4.</p> </li> </ul> </li> </ul>"},{"location":"index.en/","title":"Index.en","text":"<p>preparing</p>"},{"location":"epub/preposition/","title":"1\ubb381\ub2f5 \uc601\ubb38\uc804\uce58\uc0ac","text":"<p>\uc804\uce58\uc0ac \ud45c\ud604\uc5d0 \uc790\uc2e0\uac10\uc744! </p>"},{"location":"epub/preposition/#11","title":"\u300e\ubbf8\uc0681\ubb381\ub2f5 \uc601\ubb38 \uc804\uce58\uc0ac\u300f \uc804\uc790\ucc45","text":"<p> \uc608\uc2a424 \uad6c\ub9e4 open_in_new Play\ubd81 \uad6c\ub9e4 open_in_new </p> <p>\uc77d\uae30\ub098 \ub4e3\uae30\uc640\ub294 \ub2ec\ub9ac, \uc4f0\uae30\ub098 \ub9d0\ud560 \ub54c\uc5d0 \uc804\uce58\uc0ac \ud45c\ud604\uc740 \ub9ce\uc774 \uace0\ubbfc\ud558\uac8c \ub429\ub2c8\ub2e4.</p> <p>\uc704\uce58, \uc6c0\uc9c1\uc784, \uc2dc\uac04 \uad00\ub828 \uc804\uce58\uc0ac \ud45c\ud604\uc740 \uaddc\uce59\uc801\uc73c\ub85c \uc0dd\uac01\ud558\uace0 \uc801\uc6a9\ud560 \uc218 \uc788\uc9c0\ub9cc \ub9ce\uc740 \uc804\uce58\uc0ac \ud45c\ud604\uc774 \uad00\uc6a9\uc801\uc778 \uc219\uc5b4\uac00 \ub9ce\uc544 \uc678\uc6cc\uc57c \ud558\ub294 \uac83\uc774 \ub9ce\uc2b5\ub2c8\ub2e4. \ud2b9\ud788 \ub9d0\ud560 \ub54c \ubc14\ub85c \ud45c\ud604\uc774 \uc0dd\uac01\ub098\ub824\uba74 \ubc18\ubcf5 \ud559\uc2b5\uc774 \ud544\uc694\ud569\ub2c8\ub2e4.</p> <p>\ubc18\ubcf5\ud559\uc2b5\uc73c\ub85c \uc804\uce58\uc0ac \ud45c\ud604\uc5d0 \uc790\uc2e0\uac10\uc744 \uac00\uc838\uac00\uc138\uc694!</p> <p>\u300e\ubbf8\uc0681\ubb381\ub2f5 \uc601\ubb38 \uc804\uce58\uc0ac\u300f \uc804\uc790\ucc45\uc740 TTS(Text-To-Speech)\ub97c \ud65c\uc6a9\ud558\uc5ec \uc27d\uac8c \ub4e4\uc73c\uba70 \ubc18\ubcf5\ud559\uc2b5\uc744 \ud560 \uc218 \uc788\ub3c4\ub85d \ud558\uc600\uc2b5\ub2c8\ub2e4.</p> <p>\uc608\uc2a424 eBook \uc571\uc5d0\uc11c \u300e\ubbf8\uc0681\ubb381\ub2f5 \uc601\ubb38 \uc804\uce58\uc0ac\u300f \ucc45 TTS \uc2dc\uc5f0 \uc601\uc0c1</p> <p>TTS\ub97c \ud65c\uc6a9\ud558\uba74 \uc27d\uac8c \u300e\ubbf8\uc0681\ubb381\ub2f5 \uc601\ubb38 \uc804\uce58\uc0ac\u300f \uc804\uc790\ucc45\uc744 \uc27d\uac8c \ub4e4\uc73c\uba70 \ubc18\ubcf5\ud559\uc2b5\uc744 \ud560 \uc218 \uc788\ub3c4\ub85d \ud558\uc600\uc2b5\ub2c8\ub2e4. \ub2e4\ub9cc, \ud50c\ub7ab\ud3fc \ubcc4\ub85c TTS \ubc29\uc2dd\uc774 \ub2e4\ub974\ub2c8 \uc774\uc810 \uc720\uc758 \ubc14\ub78d\ub2c8\ub2e4.</p> <p> </p> <p>   \uc608\uc2a424 eBook \uc571\uc5d0\uc11c \u300e\ubbf8\uc0681\ubb381\ub2f5 \uc601\ubb38 \uc804\uce58\uc0ac\u300f \ucc45 TTS \uc2dc\uc5f0 \uc601\uc0c1 </p> <p>TTS\ub97c \ud65c\uc6a9\ud558\uba74 \uc27d\uac8c \u300e\ubbf8\uc0681\ubb381\ub2f5 \uc601\ubb38 \uc804\uce58\uc0ac\u300f \uc804\uc790\ucc45\uc744 \uc27d\uac8c \ub4e4\uc73c\uba70 \ubc18\ubcf5\ud559\uc2b5\uc744 \ud560 \uc218 \uc788\ub3c4\ub85d \ud558\uc600\uc2b5\ub2c8\ub2e4. \ub2e4\ub9cc, \ud50c\ub7ab\ud3fc \ubcc4\ub85c TTS \ubc29\uc2dd\uc774 \ub2e4\ub974\ub2c8 \uc774\uc810 \uc720\uc758 \ubc14\ub78d\ub2c8\ub2e4.</p> \uc608\uc2a424 \ub3c4\uc6c0\ub9d0 <p> </p> <p> \uc608\uc2a424 \uad6c\ub9e4 open_in_new </p> <p>     \uc608\uc2a424 eBook \uc571\uc740 \uc790\uccb4 TTS \ub97c \uc0ac\uc6a9\ud558\uae30 \ub54c\ubb38\uc5d0,       \uc548\ub4dc\ub85c\uc774\ub4dc\uc640 \uc544\uc774\ud3f0\uc758 \ucc28\uc774\uac00 \uc5c6\uc2b5\ub2c8\ub2e4.   </p> <p>     \uc608\uc2a424 eBook \uc571\uc758 \uacbd\uc6b0,       \u201c\ub4e3\uae30\u201d \uae30\ub2a5\uc744 \uc0ac\uc6a9\ud558\uba74,       \ud3b8\ud558\uac8c \ubc18\ubcf5\ud558\uc5ec \uba85\uc0c1\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.   </p> <p> </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc \uc608\uc2a424 \uad6c\ub9e4 \uc601\uc0c1   </p> <p> </p> <p>     \uc544\uc774\ud3f0 \uc608\uc2a424 \uad6c\ub9e4 \uc601\uc0c1   </p> \uc548\ub4dc\ub85c\uc774\ub4dc Play \ubd81 \ub3c4\uc6c0\ub9d0 <p> </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc Play\ubd81\uc758 \"\uc18c\ub9ac\ub0b4\uc5b4 \uc77d\uae30\" \uae30\ub2a5\uc740, \uc548\ub4dc\ub85c\uc774\ub4dc\uc758 \"\uae00\uc790\uc77d\uc5b4\uc8fc\uae30\" \uae30\ub2a5\uc744 \ud65c\uc6a9\ud569\ub2c8\ub2e4.   </p> <p>     \u300e\ubbf8\uc0681\ubb381\ub2f5 \uc601\ubb38 \uc804\uce58\uc0ac\u300f \uc804\uc790\ucc45\uc740 TTS(Text To Speech)\ub97c \ud65c\uc6a9\ud558\uc5ec \ubc18\ubcf5\uc801\uc73c\ub85c \ud559\uc2b5\ud560 \uc218 \uc788\ub3c4\ub85d \uc758\ub3c4 \ub418\uc5c8\uc2b5\ub2c8\ub2e4. \uc548\ub4dc\ub85c\uc774\ub4dc\uc758 Play\ubd81 \uc571\uc758 \uacbd\uc6b0,  \u201c\uc18c\ub9ac\ub0b4\uc5b4 \uc77d\uae30\u201d \uae30\ub2a5\uc744 \uc0ac\uc6a9\ud558\uba74, \ud3b8\ud558\uac8c \ubc18\ubcf5\ud558\uc5ec \uba85\uc0c1\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.   </p> <p> </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc Play\ubd81 TTS \uc2dc\uc5f0 \uc601\uc0c1   </p> <p>     Play \ubd81 \uc571\uc5d0\uc11c\uc758 \uc774 \ucc45\uc740 \ud55c\uae00\uc744 \uc18c\ub9ac\ub0b4\uc5b4 \uc77d\uc9c0 \uc54a\ub3c4\ub85d \uc758\ub3c4\ub418\uc5c8\uc2b5\ub2c8\ub2e4.       Play\ubd81 \uc571\uc5d0\uc11c \uc601\ubb38\uacfc \ud55c\uae00\uc744 \ub458 \ub2e4 \uc18c\ub9ac\ub0b4\uc5b4 \uc77d\ub3c4\ub85d \ud558\ub294 \uacbd\uc6b0, \uc601\ubb38\uc744 \uc81c\ub300\ub85c \uc77d\uc9c0 \ubabb\ud558\uae30 \ub54c\ubb38\uc785\ub2c8\ub2e4.       \ub300\uc2e0 \uc601\ubb38\uc744 \uc81c\ub300\ub85c \uc77d\uc744 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ud558\uc600\uace0, \uc601\ubb38\uc744 \ub4e3\uae30\ub9cc \ud574\ub3c4 \ud559\uc2b5\uc744 \ud560 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ud558\uc600\uc2b5\ub2c8\ub2e4.       (Yes24 \uc571\uc5d0\uc11c\ub294 \ud55c\uae00\uc744 \uc77d\uc5b4\uc90d\ub2c8\ub2e4.)   </p> <p> </p> <p>     \u300e\ubbf8\uc0681\ubb381\ub2f5 \uc601\ubb38 \uc804\uce58\uc0ac\u300f  \uc804\uc790\ucc45 Play\uc2a4\ud1a0\uc5b4 \uad6c\ub9e4 \uc601\uc0c1   </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc Play \ubd81 \uc571\uc758 \u201c\uc18c\ub9ac\ub0b4\uc5b4 \uc77d\uae30\u201d \uae30\ub2a5\uc758 \ubaa9\uc18c\ub9ac\ub97c \ubcc0\uacbd\ud558\uace0 \uc2f6\uc73c\uba74,       \"\u2699\ufe0f\uc124\uc815 \u2013 \uc77c\ubc18 \u2013 \uae00\uc790\uc77d\uc5b4\uc8fc\uae30\" \uc5d0\uc11c \uc124\uc815\ud574\uc8fc\uc154\uc57c\ud569\ub2c8\ub2e4.   </p> <p> </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc \uae00\uc790 \uc77d\uc5b4\uc8fc\uae30 \uc124\uc815 \ud654\uba74   </p> <p> </p> <p>     \uc74c\uc131 \ub370\uc774\ud130 \uc124\uce58   </p> <p> </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc \u201c\uae00\uc790\uc77d\uc5b4\uc8fc\uae30\u201d(TTS) \uc124\uc815 \uc601\uc0c1   </p> <p>     \uc601\ubb38 \ubaa9\uc18c\ub9ac\ub294 \u201c\uc601\uc5b4(\ubbf8\uad6d) \uc74c\uc1311\u201d \uc744 \ucd94\ucc9c\ub4dc\ub9ac\uace0,       \uac24\ub7ed\uc2dc \ud734\ub300\ud3f0\uc5d0\uc11c \uc774 \uc124\uc815\uc774 \uac00\ub2a5\ud569\ub2c8\ub2e4.       \uc601\uc0c1\uc5d0\uc11c \uc774 \uc124\uc815\ud558\ub294 \ubd80\ubd84\uae4c\uc9c0 \uc9c4\ud589\ud569\ub2c8\ub2e4.   </p> \uc544\uc774\ud3f0 Play \ubd81 \ub3c4\uc6c0\ub9d0 <p> </p> <p> Play\ubd81 \uad6c\ub9e4 open_in_new </p> <p>     \uc544\uc774\ud3f0 Play\ubd81\uc740 \"\uc18c\ub9ac\ub0b4\uc5b4 \uc77d\uae30\" \uae30\ub2a5\uc774 \uc5c6\uc2b5\ub2c8\ub2e4. \ud55c \ud654\uba74\uc5d0 \uc788\ub294 \uae00\uc790\ub9cc \uc77d\uc5b4\uc8fc\ub294, \uc544\uc774\ud3f0\uc758 \"\ud654\uba74\uc77d\uc5b4\uc8fc\uae30\" \uae30\ub2a5\uc744 \ud65c\uc6a9\ud569\ub2c8\ub2e4. \uc774\ub97c \uc704\ud55c \ubd80\ub85d \ud398\uc774\uc9c0\ub97c \ud65c\uc6a9\ud569\ub2c8\ub2e4.   </p> <p>     \uc544\uc774\ud3f0\uc758 \uacbd\uc6b0, \uc548\ub4dc\ub85c\uc774\ub4dc\uc640\ub294 \ub2e4\ub974\uac8c Play\ubd81\uc758 \uc18c\ub9ac\ub0b4\uc5b4 \uc77d\uae30 \uae30\ub2a5\uc744 \uc0ac\uc6a9\ud560 \uc218 \uc5c6\uc2b5\ub2c8\ub2e4.       \ub300\uc2e0 \uc544\uc774\ud3f0\uc758 \"\ud654\uba74\ub9d0\ud558\uae30\" \uae30\ub2a5\uc73c\ub85c \ub4e4\uc744 \uc218 \uc788\ub3c4\ub85d \ubd80\ub85d\uc744 \ub9cc\ub4e4\uc5b4 \ub450\uc5c8\uc2b5\ub2c8\ub2e4.   </p> <p> </p> <p>     \uc544\uc774\ud3f0 Play\ubd81 TTS \uc2dc\uc5f0 \uc601\uc0c1   </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc Play\ubd81 \uc571\ucc98\ub7fc \ud654\uba74\uc744 \ubcf4\uba74\uc11c \ub4e3\uae30\ub294 \ud560 \uc218 \uc5c6\uc9c0\ub9cc,       \ub4e3\uae30\ub9cc\uc73c\ub85c \ud559\uc2b5\uc744 \ud558\ub294 \uacbd\uc6b0 \ud65c\uc6a9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.   </p> <p>     \uc544\uc774\ud3f0\uc758 \u201c\ud654\uba74\ub9d0\ud558\uae30\u201d \uae30\ub2a5\uc774 \ub3d9\uc791\ud558\uc9c0 \uc54a\uc73c\uba74,       \uc544\uc774\ud3f0 \ud654\uba74\ub9d0\ud558\uae30 \uae30\ub2a5\uc744 \uc124\uc815\ud574\uc8fc\uc5b4\uc57c\ud569\ub2c8\ub2e4.   </p> <p>     \uc544\uc774\ud3f0\uc758 \u201c\ud654\uba74\ub9d0\ud558\uae30\u201d \uae30\ub2a5\uc744 \ud65c\uc131\ud654 \ud558\uc2dc\ub824\uba74       \"\u2699\ufe0f \uc124\uc815 &gt; \uc190\uc26c\uc6b4 \uc0ac\uc6a9 &gt; \ucf58\ud150\uce20 \ub9d0\ud558\uae30 &gt; \ud654\uba74 \ub9d0\ud558\uae30\" \uae30\ub2a5\uc744 \ud65c\uc131\ud654\ud558\uba74 \ub429\ub2c8\ub2e4.       \uc544\ub798 \uc601\uc0c1\uc744 \ucc38\uace0\ud574\uc8fc\uc138\uc694.   </p> <p> </p> <p>     \uc544\uc774\ud3f0\uc758 \"\ud654\uba74\ub9d0\ud558\uae30\" \uae30\ub2a5 \ud65c\uc131\ud654   </p> <p>     \uc774 \uae30\ub2a5\uc744 \uc124\uc815\ud558\uace0, \ub450 \uc190\uac00\ub77d\uc73c\ub85c \ud654\uba74 \uc0c1\ub2e8\uc5d0\uc11c \uc544\ub798\ub85c \uc4f8\uc5b4\ub0b4\ub9ac\uba74     \ud654\uba74\uc5d0 \uc788\ub294 \uae00\uc744 \uc77d\uc5b4\uc90d\ub2c8\ub2e4.       \ubbf8\uc068\uc5d0\ub4c0\uc5d0\uc11c \ub9cc\ub4e0 \uc804\uc790\ucc45\uc5d0\uc11c\ub294 \uc774 \uae30\ub2a5\uc744 \ud65c\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.   </p> <p>     \uc601\uc5b4 \uc74c\uc131\uc73c\ub85c Zoe \ud504\ub9ac\ubbf8\uc5c4\uc744 \ucd94\ucc9c\ud569\ub2c8\ub2e4.       \uc601\uc0c1\uc5d0\uc11c \uc74c\uc131 \uc124\uc815\ud558\ub294 \ubd80\ubd84\uae4c\uc9c0 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4.   </p> <p> </p> <p>    \u300e\ubbf8\uc0681\ubb381\ub2f5 \uc601\ubb38 \uc804\uce58\uc0ac\u300f  \uc804\uc790\ucc45 Play\ubd81 \uad6c\ub9e4 \uc601\uc0c1   </p>"},{"location":"epub/self-affirmation/","title":"\uc790\uae30\uae0d\uc815\ud655\uc5b8","text":""},{"location":"epub/self-affirmation/#_1","title":"\ub0b4 \uc0b6\uc744 \ud48d\uc694\ub86d\uac8c \ud558\ub294 \uc804\uc790\ucc45!","text":""},{"location":"epub/self-affirmation/#_2","title":"\u300e\uc601\uc5b4\ub85c \ud558\ub294 \ubbf8\uc068 \uc790\uae30\uae0d\uc815\ud655\uc5b8\u300f","text":"<p> \uc608\uc2a424 \uad6c\ub9e4 open_in_new Play\ubd81 \uad6c\ub9e4 open_in_new </p> <p>\uc601\uc5b4\ub97c \uacf5\ubd80\ud560 \ub54c\ub294 \ubb38\uc7a5\uc744 \uc678\uc6b0\ub294 \uac83\uc774 \uc88b\uc740 \ubc29\ubc95\uc785\ub2c8\ub2e4. \uc601\uc5b4 \ubb38\uc7a5\uc744 \uc554\uae30\ud558\uba70, \uc790\uc874\uac10\uc744 \ud0a4\uc6b8 \uc218 \uc788\ub3c4\ub85d \ub098\ub97c \uae0d\uc815\ud574 \uc8fc\ub294 \ud655\uc5b8 \uc704\uc8fc\ub85c \uad6c\uc131\ud558\uba74 \uc88b\uaca0\ub2e4\ub294 \uc0dd\uac01\uc5d0 \uc774 \ucc45\uc744 \ud3b8\ucc2c\ud558\uac8c \ub418\uc5c8\uc2b5\ub2c8\ub2e4.</p> <p>\uc548\ub4dc\ub85c\uc774\ub4dc Play \ubd81 \uae30\ub2a5\uc778 \"\uc18c\ub9ac\ub0b4\uc5b4 \uc77d\uae30\" \uae30\ub2a5\uc744 \uc0ac\uc6a9\ud558\uba74, \ud3b8\ud558\uac8c \ubc18\ubcf5\ud558\uc5ec \uba85\uc0c1\ud560 \uc218 \uc788\uace0, \uc601\uc5b4\uc5d0 \uc775\uc219\ud574\uc9d0\uacfc \ub3d9\uc2dc\uc5d0 \uc0b6\uc774 \ud48d\uc694\ub85c\uc6cc\uc9c0\ub294 \uac83\uc744 \ub290\ub084 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p> <p>\u300e\uc601\uc5b4\ub85c \ud558\ub294 \ubbf8\uc068 \uc790\uae30\uae0d\uc815\ud655\uc5b8 \uc804\uc790\ucc45\uc740 TTS(Text-To-Speech)\ub97c \ud65c\uc6a9\ud558\uc5ec \uc27d\uac8c \ub4e4\uc73c\uba70 \ubc18\ubcf5\ud559\uc2b5\uc744 \ud560 \uc218 \uc788\ub3c4\ub85d \ud558\uc600\uc2b5\ub2c8\ub2e4.</p>"},{"location":"epub/self-affirmation/#tts","title":"TTS \uc2dc\uc5f0","text":"<p>   \uc548\ub4dc\ub85c\uc774\ub4dc Play\ubd81 \uc571\uc5d0\uc11c \u300e\uc601\uc5b4\ub85c \ud558\ub294 \ubbf8\uc068 \uc790\uae30\uae0d\uc815\ud655\uc5b8\u300f \ucc45 TTS \uc2dc\uc5f0 \uc601\uc0c1 </p> <p>TTS\ub97c \ud65c\uc6a9\ud558\uba74 \uc27d\uac8c \u300e\ubbf8\uc0681\ubb381\ub2f5 \uc601\ubb38 \uc804\uce58\uc0ac\u300f \uc804\uc790\ucc45\uc744 \uc27d\uac8c \ub4e4\uc73c\uba70 \ubc18\ubcf5\ud559\uc2b5\uc744 \ud560 \uc218 \uc788\ub3c4\ub85d \ud558\uc600\uc2b5\ub2c8\ub2e4. \ub2e4\ub9cc, \ud50c\ub7ab\ud3fc \ubcc4\ub85c TTS \ubc29\uc2dd\uc774 \ub2e4\ub974\ub2c8 \uc774\uc810 \uc720\uc758 \ubc14\ub78d\ub2c8\ub2e4.</p> <p>\ud50c\ub7ab\ud3fc \ubcc4\ub85c \ubcf4\uae30</p> \uc608\uc2a424 \ub3c4\uc6c0\ub9d0 <p> </p> <p> \uc608\uc2a424 \uad6c\ub9e4 open_in_new </p> <p>     \uc608\uc2a424 eBook \uc571\uc740 \uc790\uccb4 TTS \ub97c \uc0ac\uc6a9\ud558\uae30 \ub54c\ubb38\uc5d0, \uc548\ub4dc\ub85c\uc774\ub4dc\uc640 \uc544\uc774\ud3f0\uc758 \ucc28\uc774\uac00 \uc5c6\uc2b5\ub2c8\ub2e4.   </p> <p>     \uc608\uc2a424 eBook \uc571\uc758 \uacbd\uc6b0,       \"\ub4e3\uae30\" \uae30\ub2a5\uc744 \uc0ac\uc6a9\ud558\uba74,       \ud3b8\ud558\uac8c \ubc18\ubcf5\ud558\uc5ec \uba85\uc0c1\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.   </p> <p>     \uc774 \ucc45\uc740 \ud55c\uae00\uc744 \uc18c\ub9ac\ub0b4\uc5b4 \uc77d\uc9c0 \uc54a\ub3c4\ub85d \uc758\ub3c4\ub418\uc5c8\uc2b5\ub2c8\ub2e4.       \ub300\uc2e0 \uc601\ubb38\uc744 \uc81c\ub300\ub85c \uc77d\uc744 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ud558\uc600\uace0, \uc601\ubb38\uc744 \ub4e3\uae30\ub9cc \ud574\ub3c4 \ud559\uc2b5\uc744 \ud560 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ud558\uc600\uc2b5\ub2c8\ub2e4.   </p> <p> </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc \uc608\uc2a424 \uad6c\ub9e4 \uc601\uc0c1   </p> <p> </p> <p>     \uc544\uc774\ud3f0 \uc608\uc2a424 \uad6c\ub9e4 \uc601\uc0c1   </p> \uc548\ub4dc\ub85c\uc774\ub4dc Play \ubd81 \ub3c4\uc6c0\ub9d0 <p> </p> <p> Play\ubd81 \uad6c\ub9e4 open_in_new </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc Play\ubd81\uc758 \"\uc18c\ub9ac\ub0b4\uc5b4 \uc77d\uae30\" \uae30\ub2a5\uc740, \uc548\ub4dc\ub85c\uc774\ub4dc\uc758 \"\uae00\uc790\uc77d\uc5b4\uc8fc\uae30\" \uae30\ub2a5\uc744 \ud65c\uc6a9\ud569\ub2c8\ub2e4.   </p> <p>     \u300e\uc601\uc5b4\ub85c \ud558\ub294 \ubbf8\uc068 \uc790\uae30\uae0d\uc815\ud655\uc5b8\u300f  \uc804\uc790\ucc45\uc740      TTS(Text To Speech)\ub97c \ud65c\uc6a9\ud558\uc5ec     \ubc18\ubcf5\uc801\uc73c\ub85c \ud559\uc2b5\ud560 \uc218 \uc788\ub3c4\ub85d \uc758\ub3c4 \ub418\uc5c8\uc2b5\ub2c8\ub2e4.   </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc\uc758 Play\ubd81 \uc571\uc758 \uacbd\uc6b0,\u00a0      \"\uc18c\ub9ac\ub0b4\uc5b4 \uc77d\uae30\" \uae30\ub2a5\uc744 \uc0ac\uc6a9\ud558\uba74,\u00a0      \ud3b8\ud558\uac8c \ubc18\ubcf5\ud558\uc5ec \uba85\uc0c1\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.   </p> <p>     \uc774 \ucc45\uc740 \ud55c\uae00\uc744 \uc18c\ub9ac\ub0b4\uc5b4 \uc77d\uc9c0 \uc54a\ub3c4\ub85d \uc758\ub3c4\ub418\uc5c8\uc2b5\ub2c8\ub2e4.     \ub300\uc2e0 \uc601\ubb38\uc744 \uc81c\ub300\ub85c \uc77d\uc744 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ud558\uc600\uace0, \uc601\ubb38\uc744 \ub4e3\uae30\ub9cc \ud574\ub3c4 \ud559\uc2b5\uc744 \ud560 \uc218 \uc788\ub3c4\ub85d \uad6c\uc131\ud558\uc600\uc2b5\ub2c8\ub2e4.   </p> <p> </p> <p>    \u300e\uc601\uc5b4\ub85c \ud558\ub294 \ubbf8\uc068 \uc790\uae30\uae0d\uc815\ud655\uc5b8\u300f \uc804\uc790\ucc45 Play\uc2a4\ud1a0\uc5b4 \uad6c\ub9e4 \uc601\uc0c1   </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc Play \ubd81 \uc571\uc758 \u201c\uc18c\ub9ac\ub0b4\uc5b4 \uc77d\uae30\u201d \uae30\ub2a5\uc758 \ubaa9\uc18c\ub9ac\ub97c \ubcc0\uacbd\ud558\uace0 \uc2f6\uc73c\uba74,       \"\u2699\ufe0f\uc124\uc815 \u2013 \uc77c\ubc18 \u2013 \uae00\uc790\uc77d\uc5b4\uc8fc\uae30\" \uc5d0\uc11c \uc124\uc815\ud574\uc8fc\uc154\uc57c\ud569\ub2c8\ub2e4.   </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc \uae00\uc790 \uc77d\uc5b4\uc8fc\uae30 \uc124\uc815 \ud654\uba74   </p> <p>     \uc74c\uc131 \ub370\uc774\ud130 \uc124\uce58   </p> <p> </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc \u201c\uae00\uc790\uc77d\uc5b4\uc8fc\uae30\u201d(TTS) \uc124\uc815 \uc601\uc0c1   </p> <p>     \uc601\ubb38 \ubaa9\uc18c\ub9ac\ub294 \u201c\uc601\uc5b4(\ubbf8\uad6d) \uc74c\uc1311\u201d \uc744 \ucd94\ucc9c\ub4dc\ub9ac\uace0,       \uac24\ub7ed\uc2dc \ud734\ub300\ud3f0\uc5d0\uc11c \uc774 \uc124\uc815\uc774 \uac00\ub2a5\ud569\ub2c8\ub2e4.       \uc601\uc0c1\uc5d0\uc11c \uc774 \uc124\uc815\ud558\ub294 \ubd80\ubd84\uae4c\uc9c0 \uc9c4\ud589\ud569\ub2c8\ub2e4.   </p>  \uc544\uc774\ud3f0 Play \ubd81 \ub3c4\uc6c0\ub9d0 <p>     \uc544\uc774\ud3f0\uc758 \uacbd\uc6b0, \uc548\ub4dc\ub85c\uc774\ub4dc\uc640\ub294 \ub2e4\ub974\uac8c Play\ubd81\uc758 \uc18c\ub9ac\ub0b4\uc5b4 \uc77d\uae30 \uae30\ub2a5\uc744 \uc0ac\uc6a9\ud560 \uc218 \uc5c6\uc2b5\ub2c8\ub2e4.       \ub300\uc2e0 \uc544\uc774\ud3f0\uc758 \u201c\ud654\uba74\ub9d0\ud558\uae30\u201d \uae30\ub2a5\uc73c\ub85c \ub4e4\uc744 \uc218 \uc788\ub3c4\ub85d \ubd80\ub85d\uc744 \ub9cc\ub4e4\uc5b4 \ub450\uc5c8\uc2b5\ub2c8\ub2e4.   </p> <p> </p> <p>     \uc544\uc774\ud3f0 Play\ubd81 TTS \uc2dc\uc5f0 \uc601\uc0c1   </p> <p> Play\ubd81 \uad6c\ub9e4 open_in_new </p> <p>     \uc548\ub4dc\ub85c\uc774\ub4dc Play\ubd81 \uc571\ucc98\ub7fc \ud654\uba74\uc744 \ubcf4\uba74\uc11c \ub4e3\uae30\ub294 \ud560 \uc218 \uc5c6\uc9c0\ub9cc,     \ub4e3\uae30\ub9cc\uc73c\ub85c \ud559\uc2b5\uc744 \ud558\ub294 \uacbd\uc6b0 \ud65c\uc6a9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.   </p> <p>     \uc544\uc774\ud3f0\uc758 \u201c\ud654\uba74\ub9d0\ud558\uae30\u201d \uae30\ub2a5\uc774 \ub3d9\uc791\ud558\uc9c0 \uc54a\uc73c\uba74,     \uc544\uc774\ud3f0 \ud654\uba74\ub9d0\ud558\uae30 \uae30\ub2a5\uc744 \uc124\uc815\ud574\uc8fc\uc5b4\uc57c\ud569\ub2c8\ub2e4.   </p> <p>     \uc544\uc774\ud3f0\uc758 \u201c\ud654\uba74\ub9d0\ud558\uae30\u201d \uae30\ub2a5\uc744 \ud65c\uc131\ud654 \ud558\uc2dc\ub824\uba74     \"\u2699\ufe0f \uc124\uc815 &gt; \uc190\uc26c\uc6b4 \uc0ac\uc6a9 &gt; \ucf58\ud150\uce20 \ub9d0\ud558\uae30 &gt; \ud654\uba74 \ub9d0\ud558\uae30\" \uae30\ub2a5\uc744 \ud65c\uc131\ud654\ud558\uba74 \ub429\ub2c8\ub2e4.     \uc544\ub798 \uc601\uc0c1\uc744 \ucc38\uace0\ud574\uc8fc\uc138\uc694.   </p> <p> </p> <p>     \uc544\uc774\ud3f0\uc758 \u201c\ud654\uba74\ub9d0\ud558\uae30\u201d \uae30\ub2a5 \ud65c\uc131\ud654   </p> <p>     \uc774 \uae30\ub2a5\uc744 \uc124\uc815\ud558\uace0, \ub450 \uc190\uac00\ub77d\uc73c\ub85c \ud654\uba74 \uc0c1\ub2e8\uc5d0\uc11c \uc544\ub798\ub85c \uc4f8\uc5b4\ub0b4\ub9ac\uba74     \ud654\uba74\uc5d0 \uc788\ub294 \uae00\uc744 \uc77d\uc5b4\uc90d\ub2c8\ub2e4.     \ubbf8\uc068\uc5d0\ub4c0\uc5d0\uc11c \ub9cc\ub4e0 \uc804\uc790\ucc45\uc5d0\uc11c\ub294 \uc774 \uae30\ub2a5\uc744 \ud65c\uc6a9\ud558\uace0 \uc788\uc2b5\ub2c8\ub2e4.   </p> <p>     \uc601\uc5b4 \uc74c\uc131\uc73c\ub85c Zoe \ud504\ub9ac\ubbf8\uc5c4\uc744 \ucd94\ucc9c\ud569\ub2c8\ub2e4.     \uc601\uc0c1\uc5d0\uc11c \uc74c\uc131 \uc124\uc815\ud558\ub294 \ubd80\ubd84\uae4c\uc9c0 \ubcf4\uc5ec\uc90d\ub2c8\ub2e4.   </p> <p> </p> <p>     \u300e\uc601\uc5b4\ub85c \ud558\ub294 \ubbf8\uc068 \uc790\uae30\uae0d\uc815\ud655\uc5b8\u300f  \uc804\uc790\ucc45 Play\ubd81 \uad6c\ub9e4 \uc601\uc0c1   </p>"},{"location":"service/listening-trainer/","title":"\ub4e3\uae30 \ud2b8\ub808\uc774\ub108","text":""},{"location":"service/quiz/","title":"\ud034\uc988","text":""}]}